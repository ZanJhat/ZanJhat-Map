<CanvasWidget xmlns="runtime-namespace:Game" xmlns:zm="runtime-namespace:ZanJhat.Map">

    <PanoramaWidget />

    <StackPanelWidget Direction="Horizontal">

        <CanvasWidget Style="{Widgets/TopBarContents}">
            <LabelWidget Name="TopBar.Label" Text="World Map" />
        </CanvasWidget>

        <StackPanelWidget Direction="Vertical" Margin="10, 0">

            <CanvasWidget Size="0, 10" />

            <CanvasWidget>
                <RectangleWidget FillColor="0, 0, 0, 192" OutlineColor="128, 128, 128" />
                <zm:WorldMapWidget Name="MapContent" Margin="1, 1" />
                <LabelWidget Name="InfoLabel" FontScale="1" DropShadow="true" HorizontalAlignment="Near" VerticalAlignment="Far" Margin="2, 2" />
                <RectangleWidget FillColor="255, 255, 255, 255" OutlineColor="0, 0, 0, 0" Subtexture="{Textures/Map/CompassDirections}" Size="64, 64" HorizontalAlignment="Far" VerticalAlignment="Near" Margin="2, 2" TextureLinearFilter="false" />
            </CanvasWidget>

            <CanvasWidget Size="0, 10" />

            <StackPanelWidget HorizontalAlignment="Center" VerticalAlignment="Center">
                <SliderWidget Name="ZoomSlider" Size="Infinity, 60" VerticalAlignment="Center" />
                <CanvasWidget Size="10, 0" />
                <BevelledButtonWidget Name="LocationButton" Size="140, 60" Text="Location" VerticalAlignment="Center" />
                <CanvasWidget Size="10, 0" />
                <BevelledButtonWidget Name="MarkerButton" Size="140, 60" Text="Marker" VerticalAlignment="Center" />
                <CanvasWidget Size="10, 0" />
                <BevelledButtonWidget Name="MoreButton" Size="140, 60" Text="More" VerticalAlignment="Center" />
            </StackPanelWidget>

            <CanvasWidget Size="0, 10" />

        </StackPanelWidget>

    </StackPanelWidget>

    <ClearWidget ClearColor="false" ClearDepth="true" Depth="1" />

</CanvasWidget>