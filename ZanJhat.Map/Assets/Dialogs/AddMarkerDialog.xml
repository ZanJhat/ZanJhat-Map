<CanvasWidget xmlns="runtime-namespace:Game">

    <CanvasWidget Size="600, 420" ClampToBounds="true" HorizontalAlignment="Center" VerticalAlignment="Center">
        <BevelledRectangleWidget Style="{Styles/DialogArea}" />

        <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" Margin="10, 0" IsVisible="true">

            <StackPanelWidget Direction="Vertical">

                <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <LabelWidget Text="Add Marker" HorizontalAlignment="Center" Margin="0, 15" />
                </StackPanelWidget>

                <CanvasWidget Size="Infinity, Infinity">
                    <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">

                        <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 5">
                            <LabelWidget Text="Name" Color="128, 128, 128" VerticalAlignment="Center" />
                            
                            <CanvasWidget Size="360, 50" VerticalAlignment="Center" Margin="10, 0">
                                <BevelledRectangleWidget Style="{Styles/TextBoxArea}" />
                                <TextBoxWidget Name="NameTextBox" Title="Name" VerticalAlignment="Center" MaximumLength="16" Size="360, 50" Margin="5, 0" />
                            </CanvasWidget>
                            
                            <BevelledButtonWidget Name="ColorButton" Style="{Styles/ButtonStyle_ColorPicker}" VerticalAlignment="Center" />
                        </StackPanelWidget>

                        <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 5">
                            <LabelWidget Text="X" VerticalAlignment="Center" Color="128, 128, 128" />
                            <CanvasWidget Size="120, 50" Margin="5, 0" VerticalAlignment="Center">
                                <BevelledRectangleWidget Style="{Styles/TextBoxArea}" />
                                <TextBoxWidget Name="XTextBox" Title="X" VerticalAlignment="Center" MaximumLength="16" Size="120, 50" Margin="5, 0" />
                            </CanvasWidget>
                            
                            <CanvasWidget Size="10, 0" />
                            
                            <LabelWidget Text="Y" VerticalAlignment="Center" Color="128, 128, 128" />
                            <CanvasWidget Size="120, 50" Margin="5, 0" VerticalAlignment="Center">
                                <BevelledRectangleWidget Style="{Styles/TextBoxArea}" />
                                <TextBoxWidget Name="YTextBox" Title="Y" VerticalAlignment="Center" MaximumLength="16" Size="120, 50" Margin="5, 0" />
                            </CanvasWidget>
                            
                            <CanvasWidget Size="10, 0" />
                            
                            <LabelWidget Text="Z" VerticalAlignment="Center" Color="128, 128, 128" />
                            <CanvasWidget Size="120, 50" Margin="5, 0" VerticalAlignment="Center">
                                <BevelledRectangleWidget Style="{Styles/TextBoxArea}" />
                                <TextBoxWidget Name="ZTextBox" Title="Z" VerticalAlignment="Center" MaximumLength="16" Size="120, 50" Margin="5, 0" />
                            </CanvasWidget>
                        </StackPanelWidget>
                        
                        <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 5">
                            <LabelWidget Text="Clamp To Edge" Color="128, 128, 128" VerticalAlignment="Center" />
                            
                            <CheckboxWidget Name="ClampToEdgeCheckbox" VerticalAlignment="Center" IsAutoCheckingEnabled="false" Margin="10, 0" />
                        </StackPanelWidget>

                    </StackPanelWidget>
                </CanvasWidget>

            </StackPanelWidget>
            
            <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Far">
                    <LabelWidget Name="StateLabel" HorizontalAlignment="Center" Margin="0, 10" />
                </StackPanelWidget>

            <UniformSpacingPanelWidget Direction="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10, 15">
                <BevelledButtonWidget Style="{Styles/ButtonStyle_160x60}" HorizontalAlignment="Center" Name="AddButton" Text="Add" />
                <BevelledButtonWidget Style="{Styles/ButtonStyle_160x60}" HorizontalAlignment="Center" Name="CancelButton" Text="Cancel" />
            </UniformSpacingPanelWidget>

        </StackPanelWidget>

    </CanvasWidget>
</CanvasWidget>